# Backend Environment Variables
# Copy this file to .env and fill in the values

# Neon Database (get from console.neon.tech)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Clerk Authentication (get from dashboard.clerk.com)
# These are stored as secrets in Cloudflare Workers, not in this file for production
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# Super Admin Email (the email that can become super admin)
INITIAL_SUPER_ADMIN_EMAIL=your_super_admin_email@example.com

# Node Environment
NODE_ENV=production